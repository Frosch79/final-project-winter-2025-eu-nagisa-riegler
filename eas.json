{
  "cli": {
    "version": ">= 16.0.0",
    "appVersionSource": "remote"
  },

  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "extends": "base",
      "channel": "development",
      "env": {
        "NODE_ENV": "development"
      },
      "ios": {
        "simulator": true
      },
      "android": {}
    },

    "preview": {
      "distribution": "internal",
      "developmentClient": true,
      "channel": "preview",
      "extends": "base",
      "android": {
        "buildType": "apk"
      }
    },

    "production": {
      "autoIncrement": true,
      "channel": "production",
      "extends": "base"
    },

    "base": {
      "env": {
        "NODE_ENV": "production",
        "EXPO_USE_FAST_RESOLVER": "1"
      }
    }
  },

  "submit": {
    "production": {}
  }
}
